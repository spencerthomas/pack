# Harbor benchmark runs: provider keys + optional observability.
# Copy to .env and fill in real values. Never commit .env.

# --- Model providers ---
# At least one provider key is required. OpenRouter covers most TB2 runs.
OPENROUTER_API_KEY=
# Optional direct-provider keys:
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GROQ_API_KEY=

# --- Sandbox backends (optional) ---
# Daytona used when Harbor is configured with --env-type daytona.
# DAYTONA_API_KEY=

# --- LangSmith observability ---
# Wire these four to activate step-level tracing. Grab a key at:
# https://smith.langchain.com/settings
#
# LANGSMITH_EXPERIMENT ties runs to an experiment/project page in the UI.
# LANGCHAIN_TRACING_V2 is the master switch — leaving it unset disables all
# tracing so the wrapper falls back to the no-trace path.
LANGSMITH_API_KEY=
LANGSMITH_EXPERIMENT=pack-tb2
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=pack-tb2
